


program: header parfor_space parfor_parameters body


parfor_parameters: "PARAMETERS" declaration ("," declaration)*

header: "PROGRAM" "(" string ")" 

parfor_space: "OFFLOAD_PARFOR_1D_PARAM" "(" IDENT "," expression "," parfor_parameters_list ")" 
parfor_parameters_list: "(" parameter ("," parameter)* ")"
parameter: IDENT

body: "BEGIN" statement+ "END_PROGRAM"

statement: for_statement
| if_statement
| declaration ";"
| assignment ";"


for_statement: "for" "(" for_loop_var ";" condition ";" increment ")" block

if_statement: "if" "(" condition ")" block

for_loop_var: type IDENT "=" expression 


condition: IDENT compare_operator expression

compare_operator: "<" | ">" 
|  "<=" | ">=" 
| "==" | "!="

increment: IDENT "++" | IDENT "--"

declaration: "const" type IDENT -> const_decl
| type IDENT -> decl

type: "int" -> int
| "float" -> float
| "fixed_size_vector" "<" type "," expression ">"  "&"


block: "{" statement* "}"

assignment: lhs "=" expression

lhs: IDENT ( "[" expression ("," expression)*  "]" )?

expression: limit_expr | number_term | lhs

limit_expr: "limit" "<" expression ">" "(" expression ")"
number_term: NUMBER -> number

// Define the Comment Terminals
COMMENT: "//" /[^\n]/* | "/*" /.*?/ "*/"

// Instruct the lexer to skip them
%ignore COMMENT
%ignore /\s+/ // Ignores whitespace


string : ESCAPED_STRING

%import common.ESCAPED_STRING
%import common.CNAME -> IDENT
%import common.NUMBER
%import common.WS_INLINE
%import common.WS
%ignore WS_INLINE
