PROGRAM("vecmath.cc:420")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A1, B1, A2, B2, A3, B3, C))

PARAMETERS
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& A1,
        const fixed_size_matrix<rlmm_float_small, 1024, 1024>& B1,
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& A2,
        const fixed_size_matrix<rlmm_float_small, 1024, 1024>& B2,
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& A3,
        const fixed_size_matrix<rlmm_float_small, 1024, 1024>& B3,
        flexible_rows_matrix<rlmm_float, 16384, 1024>& C

BEGIN
            float sum1 = 0.f;
            float sum2 = 0.f;
            float sum3 = 0.f;
            for (size_t l_idx = 0; l_idx < 1024; ++l_idx)
            {
                const int k = int(l_idx);

                const float term1 = A1[i, k] * B1[k, j];
                OVERFLOW_CHECK_ADD(sum1, term1);
                sum1 += term1;

                const float term2 = A2[i, k] * B2[k, j];
                OVERFLOW_CHECK_ADD(sum2, term2);
                sum2 += term2;

                const float term3 = A3[i, k] * B3[k, j];
                OVERFLOW_CHECK_ADD(sum3, term3);
                sum3 += term3;
            }
            C[i, j] += sum1 + sum2 + sum3;

END_PROGRAM