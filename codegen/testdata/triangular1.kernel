PROGRAM("TransformerBlock.cc:552")

OFFLOAD_PARFOR_3D_TRIANGULAR_PARAM(hi, i, j, seq_len, (d_scores, d_raw, attn_w, seq_len, d_scores_rows, d_scores_cols, d_raw_rows, d_raw_cols))

PARAMETERS
        fixed_size_levels_rows_cols_matrix<rlmm_float, HeadsIndex, 16384, 16384>& d_scores = ws.d_scores;
        fixed_size_levels_rows_cols_matrix<rlmm_float, HeadsIndex, 16384, 16384>& d_raw = ws.d_raw;
        const PositionIndex seq_len = fwd.seq_len;
        [[maybe_unused]] const int d_scores_rows = seq_len;
        [[maybe_unused]] const int d_scores_cols = seq_len;
        [[maybe_unused]] const int d_raw_rows = seq_len;
        [[maybe_unused]] const int d_raw_cols = seq_len;
        const flexible_rows_cols_levels_matrix<rlmm_float, HeadsIndex, 16384, 16384>& attn_w = fwd.attn_w;

BEGIN
        {
            float row_dot = 0.f;
            for (const auto k : limit<16384>(inc(i)))
                row_dot += d_scores[hi, i, k] * attn_w[hi, i, k];
            d_raw[hi, i, j] = attn_w[hi, i, j] * (d_scores[hi, i, j] - row_dot);
        }

END_PROGRAM