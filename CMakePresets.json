{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "default-fastfork",
      "displayName": "Default FastFork",
      "description": "FastFork backend with no offload",
      "inherits": "base",
      "cacheVariables": {
        "PARALLEL_BACKEND": "fastfork",
        "OFFLOAD_BACKEND": "none"
      }
    },
    {
      "name": "fastfork-vulkan",
      "displayName": "FastFork + Vulkan Offload",
      "description": "FastFork backend with Vulkan offload mode enabled",
      "inherits": "base",
      "cacheVariables": {
        "PARALLEL_BACKEND": "fastfork",
        "OFFLOAD_BACKEND": "vulkan"
      }
    },
    {
      "name": "openmp-hip",
      "displayName": "OpenMP + HIP Offload",
      "description": "OpenMP backend with HIP offload mode and explicit HIP root",
      "inherits": "base",
      "cacheVariables": {
        "PARALLEL_BACKEND": "openmp",
        "OFFLOAD_BACKEND": "hip",
        "HIP_ROOT": "/opt/rocm"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-default-fastfork",
      "displayName": "Build Default FastFork",
      "configurePreset": "default-fastfork"
    },
    {
      "name": "build-fastfork-vulkan",
      "displayName": "Build FastFork + Vulkan",
      "configurePreset": "fastfork-vulkan"
    },
    {
      "name": "build-openmp-hip",
      "displayName": "Build OpenMP + HIP",
      "configurePreset": "openmp-hip"
    }
  ]
}
